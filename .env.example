# ============================================
# Campus QA 部署环境变量
# 复制此文件为 .env 并修改对应值
# ============================================

# MySQL 数据库密码（必改！）
DB_PASSWORD=your_secure_password_here

# MySQL 端口（可选，默认 3306）
DB_PORT=3306

# 前端端口（可选，默认 80）
FRONTEND_PORT=80

# JWT 密钥（必改！生产环境请使用随机字符串）
JWT_SECRET=change-me-to-a-random-string-here
ADMIN_JWT_SECRET=change-me-to-another-random-string-here
